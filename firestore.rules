rules_version = '2';

// Apply via Firebase console:
//   Firestore Database → Rules tab → paste this content → Publish
//
// Or via CLI (if you install firebase-tools):
//   firebase deploy --only firestore:rules --project askemy-88b46

service cloud.firestore {
  match /databases/{database}/documents {

    // Public site reads meta docs (current location, copy overrides).
    // Only authenticated admin can write.
    match /meta/{docId} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // Anyone can create a request (from the chat) and update their own in-flight session.
    // Only authenticated admin can read back the list or delete.
    // Basic size cap to prevent abuse.
    match /requests/{doc} {
      allow create: if request.resource.data.messages is list
                   && request.resource.data.messages.size() <= 100;
      allow update: if request.resource.data.messages is list
                   && request.resource.data.messages.size() <= 100
                   && request.resource.data.messages.size() >= resource.data.messages.size();
      allow read, delete: if request.auth != null;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
